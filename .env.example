# Copy to .env and fill in values for your deployment.
# All variables have sensible development defaults; only override what you need.

# --- Transport ---
# Full pytak-compatible URL for the TAK server CoT input.
# tcp:// for plaintext, tcps:// for SSL/TLS.
COT_URL=tcp://127.0.0.1:8087

# --- CoT semantics ---
# Seconds a track stays on the map after its last update before going stale.
STALE_SECONDS=60

# Prefix for CoT UIDs — change this if you run multiple gateway instances
# against the same TAK server to avoid UID collisions.
UID_PREFIX=cvgw

# Minimum detection confidence to assert a non-unknown affiliation (0.0–1.0).
CONFIDENCE_FLOOR=0.40

# --- FreeTAKServer compatibility ---
# Set to "1" to enable pytak's FTS_COMPAT throttle (random inter-event sleep).
# Set to "" (empty string) to disable — useful for log:// dry-runs.
FTS_COMPAT=1

# --- Fake track generator (v1 only) ---
# Number of fake tracks to emit.
FAKE_TRACK_COUNT=3

# Seconds between position updates for each track.
FAKE_INTERVAL=6

# Starting position of the fake track line (decimal degrees).
FAKE_START_LAT=37.7749
FAKE_START_LON=-122.4194

# Per-tick movement in degrees (~0.0002 deg lat ≈ 22 m).
FAKE_STEP_LAT=0.0002
FAKE_STEP_LON=0.0002

# Lateral spacing between parallel tracks (degrees longitude).
FAKE_TRACK_SPACING_LON=0.0005
